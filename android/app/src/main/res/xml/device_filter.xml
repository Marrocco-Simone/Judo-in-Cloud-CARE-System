<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 
        USB device filter for UVC cameras.
        This accepts devices with:
        - Class 239 (Miscellaneous Device Class) with Subclass 2 (Common Class) and Protocol 1 (Interface Association Descriptor)
        - OR Class 14 (Video Class) devices
        
        Leaving vendor-id and product-id empty matches all devices with the specified class.
    -->
    
    <!-- UVC Interface Association Descriptor device -->
    <usb-device class="239" subclass="2" protocol="1" />
    
    <!-- USB Video Class device -->
    <usb-device class="14" subclass="1" protocol="0" />
    <usb-device class="14" subclass="2" protocol="0" />
    
    <!-- Generic video interface fallback -->
    <usb-device class="14" />
</resources>
